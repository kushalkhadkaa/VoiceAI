APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:1.7b
OLLAMA_FALLBACK_MODELS=qwen3:4b,llama3.2:3b,llama3.2:1b
OLLAMA_TEMPERATURE=0.35
OLLAMA_NUM_PREDICT=180
OLLAMA_KEEP_ALIVE=10m
OLLAMA_TIMEOUT_SECONDS=60
OLLAMA_RETRIES=1

WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto

PIPER_BINARY=piper
PIPER_NEPALI_VOICE=./models/piper/ne_NP-chitwan-medium.onnx
PIPER_ENGLISH_VOICE=./models/piper/en_US-lessac-medium.onnx
PIPER_AUDIO_CACHE_DIR=.local/audio_cache
AUDIO_WORK_DIR=.local/audio_work
MAX_UPLOAD_BYTES=26214400
MAX_RECORDING_SECONDS=30
KEEP_TURN_AUDIO=false

LOW_LATENCY_MODE=true
QUALITY_MODE=false

# LLM Providers Configuration
LLM_PROVIDER=local
LOCAL_MODEL=qwen2.5:7b
LOCAL_FALLBACK_MODEL=gemma3:4b
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
CLOUD_FALLBACK_TO_LOCAL=true
CLOUD_TIMEOUT_SECONDS=30.0
CLOUD_TEMPERATURE=0.35
CLOUD_MAX_TOKENS=180
